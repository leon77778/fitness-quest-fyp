flowchart TB
    U[User]
    MC[Mobile Client: Expo / React Native]
    APP[App.js Root Controller]

    U --> MC
    MC --> APP

    subgraph Screens[Feature Screens]
        L[LoginScreen]
        O[OnboardingScreen]
        H[HomeScreen]
        P[ProgressScreen]
        OR[OracleScreen]
        E[ExerciseScreen]
        W[WalkScreen]
        PR[ProfileScreen]
        F[FailedScreen]
    end

    subgraph Shared[Shared UI Components]
        CC[CalorieChart]
        TD[TimerDisplay]
        RC[RepCounter]
        WB[WeaponBadge]
        WM[WeaponBadgesModal]
        LM[LevelUpModal]
    end

    subgraph Domain[Domain Logic Inside App.js]
        EX[Exercise Catalog]
        WE[Weapon Catalog]
        CAL[Calorie Logic]
        CLOG[Calendar Logic]
        XP[Progression Logic]
        AD[Adaptive Difficulty]
        AIG[AI Workout Gen]
        AWG[AI Walk Gen]
        GWS[groupWorkoutSessions]
    end

    SUP[lib/supabase.js
    Shared Supabase client
    Auth session persistence
    Database access]

    subgraph WalkUtils[src/utils/walk.js]
        DP[destinationPoint]
        HD[haversineDistance (distance approximation)]
        WS[save/load/clearActiveWalkState]
        GM[Google Maps URL builders]
        BWE[buildWalkSessionEntry]
        WP[computeWalkProgress]
        FMT[formatDistance / formatElapsedTime]
    end

    subgraph Device[Device / Expo APIs]
        LOC[expo-location]
        LINK[expo-linking]
        VID[expo-av Video]
        AS[AsyncStorage]
    end

    subgraph External[External Services / Data Layer]
        SA[Supabase Auth]
        PT[profiles table]
        ST[sessions table]
        WT[walk_sessions table]
        GROQ[Groq LLM API]
        SS[Supabase Storage]
    end

